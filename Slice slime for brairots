-- AVISO NA TELA
local function MostrarAviso(mensagem)
    local Aviso = Instance.new("Frame")
    Aviso.Size = UDim2.new(0, 220, 0, 50)
    Aviso.Position = UDim2.new(0.5, -110, 0.05, 0)
    Aviso.BackgroundColor3 = Color3.new(0.08, 0.08, 0.08)
    Aviso.BorderSizePixel = 2
    Aviso.BorderColor3 = Color3.new(0, 0.5, 1)
    Aviso.ZIndex = 999
    Aviso.Parent = Gui

    local TextoAviso = Instance.new("TextLabel")
    TextoAviso.Size = UDim2.new(1, -10, 1, 0)
    TextoAviso.Position = UDim2.new(0, 5, 0, 0)
    TextoAviso.BackgroundTransparency = 1
    TextoAviso.Text = mensagem
    TextoAviso.TextColor3 = Color3.new(1,1,1)
    TextoAviso.Font = Enum.Font.GothamBold
    TextoAviso.TextSize = 12
    TextoAviso.ZIndex = 1000
    TextoAviso.Parent = Aviso

    TweenService:Create(Aviso, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -110, 0.08, 0)}):Play()
    task.delay(2, function()
        TweenService:Create(Aviso, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -110, -0.05, 0)}):Play()
        task.wait(0.3)
        Aviso:Destroy()
    end)
end

-- BOTÕES DE TP (APENAS TELETRANSPORTE)
local yPos = 0.08
for Nome, Cfrm in pairs(TPs) do
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0.92, 0, 0, 38)
    Btn.Position = UDim2.new(0.04, 0, yPos, 0)
    Btn.BackgroundColor3 = Color3.new(0.12,0.12,0.12)
    Btn.BorderSizePixel = 1
    Btn.BorderColor3 = Color3.new(0,0.5,1)
    Btn.Text = "📍 "..Nome
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 11
    Btn.ZIndex = 11
    Btn.Parent = TP_Conteudo
    AdicionarSom(Btn)

    Btn.MouseButton1Click:Connect(function()
        local Char = Player.Character or Player.CharacterAdded:Wait()
        if Char and Char:FindFirstChild("HumanoidRootPart") then
            task.spawn(function()
                Char.HumanoidRootPart.CFrame = Cfrm
                MostrarAviso("✅ Teleportado para: " .. Nome)
            end)
        end
    end)
    yPos += 0.26
end

