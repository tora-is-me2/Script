-- SISTEMA DE ABAS (ATUALIZADO COM A ABA SET)
-- ==============================================
local function MudarAba(abaAtiva)
    -- Resetar todas
    TP_Aba.BackgroundColor3 = Color3.new(0.09,0.09,0.09)
    TP_Aba.TextColor3 = Color3.new(0.7,0.7,0.7)
    SET_Aba.BackgroundColor3 = Color3.new(0.09,0.09,0.09)
    SET_Aba.TextColor3 = Color3.new(0.7,0.7,0.7)
    INFO_Aba.BackgroundColor3 = Color3.new(0.09,0.09,0.09)
    INFO_Aba.TextColor3 = Color3.new(0.7,0.7,0.7)
    
    -- Esconder todos os conteúdos
    TP_Conteudo.Visible = false
    SET_Conteudo.Visible = false
    INFO_Conteudo.Visible = false

    -- Ativar aba selecionada
    if abaAtiva == "TP" then
        TP_Aba.BackgroundColor3 = Color3.new(0,0.25,0.6)
        TP_Aba.TextColor3 = Color3.new(1,1,1)
        TP_Conteudo.Visible = true
    elseif abaAtiva == "SET" then
        SET_Aba.BackgroundColor3 = Color3.new(0,0.25,0.6)
        SET_Aba.TextColor3 = Color3.new(1,1,1)
        SET_Conteudo.Visible = true
    elseif abaAtiva == "INFO" then
        INFO_Aba.BackgroundColor3 = Color3.new(0,0.25,0.6)
        INFO_Aba.TextColor3 = Color3.new(1,1,1)
        INFO_Conteudo.Visible = true
    end
end

-- CONECTAR BOTÕES DAS ABAS
