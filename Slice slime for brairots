-- LÓGICA DO NOCLIP
RunService.RenderStepped:Connect(function()
    if NoClipAtivo and Player.Character then
        local Humanoid = Player.Character:FindFirstChild("Humanoid")
        if Humanoid then
            Humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
            for _, Parte in pairs(Player.Character:GetChildren()) do
                if Parte:IsA("BasePart") then
                    Parte.CanCollide = false
                end
            end
        end
    end
end)

-- ATIVAR / DESATIVAR NOCLIP
NoClipBtn.MouseButton1Click:Connect(function()
    NoClipAtivo = not NoClipAtivo
    if NoClipAtivo then
        NoClipBtn.Text = "🔒 NOCLIP: ATIVADO"
        NoClipBtn.BackgroundColor3 = Color3.new(0, 0.5, 0.2)
        MostrarAviso("✅ NoClip ATIVADO")
    else
        NoClipBtn.Text = "🔓 NOCLIP: DESATIVADO"
        NoClipBtn.BackgroundColor3 = Color3.new(0.12,0.12,0.12)
        MostrarAviso("❌ NoClip DESATIVADO")
        -- Restaurar colisão ao desativar
        if Player.Character then
            for _, Parte in pairs(Player.Character:GetChildren()) do
                if Parte:IsA("BasePart") then
                    Parte.CanCollide = true
                end
            end
            local Humanoid = Player.Character:FindFirstChild("Humanoid")
            if Humanoid then
                Humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
            end
        end
    end
end)

