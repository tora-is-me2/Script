    BtnFechar.TextColor3 = cor
    BtnCorBorda.TextColor3 = cor
    BtnCorLetra.TextColor3 = cor
    BtnVelocidade.TextColor3 = cor
    BtnFixo.TextColor3 = cor
    
    -- Atualiza todas as labels dos botões
    local function AtualizarCores(area)
        for _,v in pairs(area:GetDescendants()) do
            if v:IsA("TextLabel") then v.TextColor3 = cor end
        end
    end
    AtualizarCores(AreaPrincipal)
    AtualizarCores(AreaEspaco)
end)

