-- SISTEMA TROCAR DE ABAS
local function MudarAba(nome)
    AreaPrincipal.Visible = (nome == "MAIN")
    AreaEspaco.Visible = (nome == "ESPAÇO")
    AreaConfig.Visible = (nome == "CONFIG")

    -- Cores das abas
    AbaPrincipal.BackgroundColor3 = nome == "MAIN" and Color3.fromRGB(40,40,40) or Color3.fromRGB(25,25,25)
    AbaPrincipal.TextColor3 = nome == "MAIN" and Color3.new(1,1,1) or Color3.new(0.7,0.7,0.7)
    
    AbaEspaco.BackgroundColor3 = nome == "ESPAÇO" and Color3.fromRGB(40,40,40) or Color3.fromRGB(25,25,25)
    AbaEspaco.TextColor3 = nome == "ESPAÇO" and Color3.new(1,1,1) or Color3.new(0.7,0.7,0.7)
    
    AbaConfig.BackgroundColor3 = nome == "CONFIG" and Color3.fromRGB(40,40,40) or Color3.fromRGB(25,25,25)
    AbaConfig.TextColor3 = nome == "CONFIG" and Color3.new(1,1,1) or Color3.new(0.7,0.7,0.7)
end

AbaPrincipal.MouseButton1Click:Connect(function() MudarAba("MAIN") end)
AbaEspaco.MouseButton1Click:Connect(function() MudarAba("ESPAÇO") end)
AbaConfig.MouseButton1Click:Connect(function() MudarAba("CONFIG") end)

-- SISTEMA ABRIR / FECHAR MENU
