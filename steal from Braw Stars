-- TROCA DE ABAS
local function MudarAba(nome)
    ContainerTP.Visible = nome == "TP"
    ContainerConfig.Visible = nome == "CONFIG"

    AbaTP.BackgroundColor3 = nome == "TP" and Color3.fromRGB(45,45,45) or Color3.fromRGB(25,25,25)
    AbaTP.TextColor3 = nome == "TP" and Color3.new(1,1,1) or Color3.new(0.7,0.7,0.7)
    
    AbaConfig.BackgroundColor3 = nome == "CONFIG" and Color3.fromRGB(45,45,45) or Color3.fromRGB(25,25,25)
    AbaConfig.TextColor3 = nome == "CONFIG" and Color3.new(1,1,1) or Color3.new(0.7,0.7,0.7)
end

AbaTP.MouseButton1Click:Connect(function() MudarAba("TP") end)
AbaConfig.MouseButton1Click:Connect(function() MudarAba("CONFIG") end)

-- ABRIR / FECHAR MENU
local aberto = false
